# Xentinel environment template
# Copy this file to .env.local and fill in deployment values.

# App / database
MONGODB_URI=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Wallet connect
# Public project id used by RainbowKit / WalletConnect. Do not put private keys here.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Xerberus Enterprise MCP powers Xentinel's core live risk intelligence.
XERBERUS_API_KEY=
XERBERUS_BASE_URL=https://mcp.xerberus.io/enterprise/mcp
XERBERUS_MCP_URL=https://mcp.xerberus.io/enterprise/mcp

# Optional explicit Enterprise/Framework credentials.
# Enterprise is used by the product APIs. Framework is available for future scorecard/evidence workflows.
XERBERUS_ENTERPRISE_API_KEY=
XERBERUS_ENTERPRISE_MCP_URL=https://mcp.xerberus.io/enterprise/mcp
XERBERUS_FRAMEWORK_API_KEY=
XERBERUS_FRAMEWORK_MCP_URL=https://mcp.xerberus.io/framework/mcp

# Smart Money Sentinel
# Accepts comma-separated wallet addresses or a JSON array of { walletAddress, label } objects.
SMART_WALLET_WATCHLIST=

# AI Chat Co-Pilot
# AI_PROVIDER can be openrouter, groq, or gemini. If empty, Xentinel tries OpenRouter -> Groq -> Gemini.
AI_PROVIDER=

OPENROUTER_API_KEY=
OPENROUTER_MODEL=

GROQ_API_KEY=
GROQ_MODEL=

GEMINI_API_KEY=
GEMINI_MODEL=
